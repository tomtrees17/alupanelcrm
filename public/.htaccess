# Apache: route everything through index.php if needed.
# The app already works with index.php?r=... so URL rewriting is optional.
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Serve existing files/directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>
